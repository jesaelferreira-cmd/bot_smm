# SERVICE (FUNÇÃO PRINCIPAL)
# =========================

def get_categories() -> List[str]:
    """Pipeline completo de processamento de categorias"""
    try:
        raw_categories = fetch_categories_from_db()
        
        # 1. Filtrar termos proibidos e lixo
        filtered = [cat for cat in raw_categories if is_valid_category(cat)]
        
        # 2. Normalizar emojis (Dicionário ou Nativo)
        normalized = [normalize_category(cat) for cat in filtered]
        
        # 3. Remover duplicatas mantendo a ordem (Unique)
        unique = list(dict.fromkeys(normalized))
        
        # 4. Ordenar por prioridade de rede social
        return sort_categories(unique)
    except Exception as e:
        print(f"Erro no pipeline de categorias: {e}")
        return []

def get_services(category_name, limit=15):
    conn = sqlite3.connect(str(DB_PATH))
    cursor = conn.cursor()
    cursor.execute(
        "SELECT service_id, name, rate, min, max FROM services WHERE category = ? AND rate > 0 ORDER BY rate ASC LIMIT ?",
        (category_name, limit),
    )
    services = cursor.fetchall()
    conn.close()
    return services

def get_service_by_id(service_id):
    conn = sqlite3.connect(str(DB_PATH))
    cursor = conn.cursor()
    # Adicionamos 'description' na consulta (o 7º item agora)
    cursor.execute(
        "SELECT service_id, name, rate, min, max, category, provider, description FROM services WHERE service_id = ?",
        (service_id,),
    )
    service = cursor.fetchone()
    conn.close()
    return service

def get_available_categories():
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    # Este comando só pega categorias de serviços cujo fornecedor está 'ONLINE'
    query = """
        SELECT DISTINCT s.category 
        FROM services s
        JOIN providers_status ps ON s.provider_id = ps.id
        WHERE ps.status = 'ONLINE'
        ORDER BY s.category ASC
    """
    
    cursor.execute(query)
    categories = [row[0] for row in cursor.fetchall()]
    conn.close()
    return categories

async def safe_edit(query, text, reply_markup):
    """Função auxiliar para editar mensagem com ou sem foto sem dar erro"""
    try:
        if query.message.caption or query.message.photo:
            await query.edit_message_caption(caption=text, reply_markup=reply_markup, parse_mode="Markdown")
        else:
            await query.edit_message_text(text=text, reply_markup=reply_markup, parse_mode="Markdown")
    except Exception as e:
        logging.error(f"Erro ao editar: {e}")

