async def category_services(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    
    # PEGA O DADO DO BOTÃO
    raw_data = query.data.replace("cat_", "")
    
    # LIMPEZA DO EMOJI: 
    # Se o nome veio como "📸 Instagram", o raw_data terá o emoji.
    # Vamos remover o emoji e o espaço inicial para buscar no banco.
    if " " in raw_data[:4]: # Se houver um espaço logo no começo (após o emoji)
        category_partial = raw_data.split(" ", 1)[1]
    else:
        category_partial = raw_data

    # Busca o nome real no banco usando LIKE
    conn = sqlite3.connect(str(DB_PATH))
    cursor = conn.cursor()
    cursor.execute(
        "SELECT DISTINCT category FROM services WHERE category LIKE ? AND rate > 0", 
        (f"%{category_partial}%",)
    )
    res = cursor.fetchone()
    conn.close()
    
    category = res[0] if res else category_partial
    services = get_services(category)
    
    # ... resto do código para gerar os botões dos serviços ...
    
    keyboard = [[InlineKeyboardButton(f"{s[1]} - R${s[2]:.2f}", callback_data=f"serv_{s[0]}") ] for s in services]
    
    # VOLTAR PARA A LISTA DE CATEGORIAS
    keyboard.append([InlineKeyboardButton("⬅️ Voltar para Categorias", callback_data="back_to_categories")])
    
    reply_markup = InlineKeyboardMarkup(keyboard)
    text = f"🚀 **SERVIÇOS: {category.upper()}**"

    if query.message.photo:
        await query.edit_message_caption(caption=text, reply_markup=reply_markup, parse_mode="Markdown")
    else:
        await query.edit_message_text(text=text, reply_markup=reply_markup, parse_mode="Markdown")
    return SELECTING_SERVICE

async def receive_service(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Captura o serviço selecionado e prepara os dados para a quantidade"""
    query = update.callback_query
    await query.answer()

    # Extrai o ID do serviço do callback (ex: serv_123 -> 123)
    service_id = query.data.replace("serv_", "")
    
    # Busca os detalhes no banco (Certifique-se que get_service_by_id retorna: 
    # [id, name, rate, min, max, category])
    service = get_service_by_id(service_id)

    if not service:
        await query.edit_message_text(text="❌ Erro: Serviço não encontrado no banco de dados.")
        return SELECTING_SERVICE

    # =========================================================
    # 🔐 SALVAMENTO CRÍTICO NO USER_DATA (Sincronizado)
    # =========================================================
    context.user_data["service_id"] = service[0]
    context.user_data["service_name"] = service[1]
    context.user_data["rate"] = float(service[2])  # Taxa por 1000
    context.user_data["min"] = int(service[3])     # Mínimo aceito
    context.user_data["max"] = int(service[4])     # Máximo aceito
    # =========================================================

    # Montagem do texto de exibição (Estilo Premium)
    text = (
        f"📦 **{service[1]}**\n\n"
        f"💰 Preço por 1000: **R$ {service[2]:.2f}**\n"
        f"📉 Mínimo: `{service[3]}` | 📈 Máximo: `{service[4]}`\n\n"
        f"❓ **Quanto deseja comprar?**\n"
        f"_(Digite apenas o número, ex: 500)_"
    )

    # Lógica do Botão Voltar (Limitando tamanho do callback para evitar erro do Telegram)
    # Pegamos a categoria original (service[5]) para o usuário poder voltar
    category_raw = service[5] if len(service) > 5 else "back"
    back_callback = f"cat_{category_raw[:40]}" 

    keyboard = [[InlineKeyboardButton("⬅️ Escolher outro Serviço", callback_data=back_callback)]]
    reply_markup = InlineKeyboardMarkup(keyboard)

    # Envio Inteligente (Trata se a mensagem anterior era foto ou texto)
    try:
        if query.message.photo:
            await query.edit_message_caption(
                caption=text, 
                reply_markup=reply_markup, 
                parse_mode="Markdown"
            )
        else:
            await query.edit_message_text(
                text=text, 
                reply_markup=reply_markup, 
                parse_mode="Markdown"
            )
    except Exception as e:
        # Fallback caso o edit falhe (ex: mensagem muito antiga)
        await query.message.reply_text(text, reply_markup=reply_markup, parse_mode="Markdown")

    return ASKING_QUANTITY

async def receive_quantity(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_data = context.user_data
    text_input = update.message.text

    # 1. Validação de entrada
    if not text_input.isdigit():
        await update.message.reply_text("⚠️ Por favor, digite apenas números (ex: 500).")
        return ASKING_QUANTITY # Use a variável de estado que você já tem

    quantity = int(text_input)

    # 2. Proteção de dados (O que evitou o KeyError: 'rate')
    rate = user_data.get('rate') # Pegando a chave correta que salvamos no receive_service
    if rate is None:
        await update.message.reply_text("⚠️ Ops, as informações do serviço expiraram. Use /comprar novamente.")
        return ConversationHandler.END

    # 3. Validação de Mínimo e Máximo (Importante para não dar erro no fornecedor)
    service_min = user_data.get('min', 0)
    service_max = user_data.get('max', 999999)

    if quantity < service_min or quantity > service_max:
        await update.message.reply_text(
            f"❌ **Quantidade Inválida!**\n"
            f"O mínimo para este serviço é **{service_min}** e o máximo é **{service_max}**.\n"
            f"Digite um valor válido:"
        )
        return ASKING_QUANTITY

    # 4. Cálculo do preço
    total_price = (rate / 1000) * quantity
    user_data['quantity'] = quantity
    user_data['total_price'] = round(total_price, 2)

    # 5. Teclado Inline (UX de Elite)
    keyboard = [
        [
            InlineKeyboardButton("✅ Confirmar Valor", callback_data="confirm_price"),
            InlineKeyboardButton("❌ Cancelar", callback_data="back_to_categories")
        ]
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)

    msg = (
        f"💰 **RESUMO DO VALOR**\n\n"
        f"📦 Serviço: {user_data.get('service_name', 'Serviço')}\n"
        f"🔢 Quantidade: {quantity}\n"
        f"💵 **Total a pagar: R$ {user_data['total_price']:.2f}**\n\n"
        f"Deseja prosseguir para o envio do link?"
    )

    await update.message.reply_text(msg, reply_markup=reply_markup, parse_mode="Markdown")
    
    # 6. Retorno do estado EXATO que está no seu main.py
    return WAIT_CONFIRM_PRICE

