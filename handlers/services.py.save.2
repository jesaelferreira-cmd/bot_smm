def detect_icon(category: str) -> str:
    """Detecta emoji baseado no nome ou retorna o Foguete como padrão"""
    cat_lower = category.lower()

    # Busca no mapa de ícones; se não achar, entrega o Foguete 🚀
    return next(
        (icon for key, icon in ICONS_MAP.items() if key in cat_lower),
        "🚀"
    )

def normalize_category(category: str) -> str:
    """Garante padronização visual respeitando emojis nativos da API"""
    category = category.strip()
    
    # Se a categoria já começa com emoji (ex: vindo da EngajaMais), mantém intacto
    if EMOJI_REGEX.match(category):
        return category 

    icon = detect_icon(category)
    return f"{icon} {category}"

def sort_categories(categories: List[str]) -> List[str]:
    """Ordenação baseada em prioridade + nome alfabético"""
    def sort_key(item: str):
        # Pega o primeiro caractere (emoji)
        emoji = item[0] if item else ""
        priority = PRIORITY_MAP.get(emoji, 99)
        
        # Nome limpo para desempate alfabético
        clean_name = item[1:].strip() if len(item) > 1 else item
        return (priority, clean_name)

    return sorted(categories, key=sort_key)

# Regex para identificar se a categoria já começa com um Emoji (UTF-8 amplo)
EMOJI_REGEX = re.compile(r'^[\U00010000-\U0010ffff\u2600-\u26ff\u2700-\u27bf]')

