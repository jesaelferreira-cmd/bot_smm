import logging
import sqlite3
from config import DB_PATH
from telegram import InlineKeyboardButton, InlineKeyboardMarkup, Update
from telegram.ext import ContextTypes, ConversationHandler

# Estados do ConversationHandler
SELECTING_SERVICE = 1
ASKING_QUANTITY = 2
ASKING_LINK = 3
CONFIRMING = 4

def get_categories():
    """Busca as categorias, filtra lixo e adiciona emojis automáticos"""
    conn = sqlite3.connect(str(DB_PATH))
    cursor = conn.cursor()
    
    # Buscamos categorias com serviços ativos
    cursor.execute("SELECT DISTINCT category FROM services WHERE rate > 0")
    rows = cursor.fetchall()
    conn.close()

    # Dicionário de Emojis por plataforma
    icones = {
        "instagram": "📸",
        "tiktok": "📱",
        "youtube": "🎥",
        "facebook": "💙",
        "twitter": "🐦",
        "x": "🐦",
        "kwai": "🧡",
        "telegram": "💎",
        "spotify": "🎧",
        "threads": "🧵"
    }

    termos_proibidos = ["desativado", "manutenção", "denúncia", "comunidade", "suporte", "provedor"]

    filtered_categories = []
    for row in rows:
        category = row[0]
        if not category: continue
        
        cat_lower = category.lower()
        
        # Filtros de limpeza
        if category.isdigit() or len(category) < 3: continue
        if any(termo in cat_lower for termo in termos_proibidos): continue

        # --- ADICIONA O EMOJI ---
        emoji = "📦" # Emoji padrão caso não identifique a rede social
        for rede, icone in icones.items():
            if rede in cat_lower:
                emoji = icone
                break
        
        # Monta o nome final: "📸 Instagram Seguidores"
        category_com_emoji = f"{emoji} {category}"
        filtered_categories.append(category_com_emoji)

    # Ordenação prioritária (agora considerando que o nome começa com emoji)
    # Usamos [2:] para ignorar o emoji e o espaço na hora de comparar o nome da rede
    prioridade = {"Instagram": 1, "TikTok": 2, "YouTube": 3, "Facebook": 4, "Telegram": 5}
    
    return sorted(
        filtered_categories, 
        key=lambda x: (prioridade.get(x[2:].split()[0], 99), x)
    )

def get_services(category_name, limit=15):
    conn = sqlite3.connect(str(DB_PATH))
    cursor = conn.cursor()
    cursor.execute(
        "SELECT service_id, name, rate, min, max FROM services WHERE category = ? AND rate > 0 ORDER BY rate ASC LIMIT ?",
        (category_name, limit),
    )
    services = cursor.fetchall()
    conn.close()
    return services

def get_service_by_id(service_id):
    conn = sqlite3.connect(str(DB_PATH))
    cursor = conn.cursor()
    # Adicionamos 'description' na consulta (o 7º item agora)
    cursor.execute(
        "SELECT service_id, name, rate, min, max, category, provider, description FROM services WHERE service_id = ?",
        (service_id,),
    )
    service = cursor.fetchone()
    conn.close()
    return service

async def safe_edit(query, text, reply_markup):
    """Função auxiliar para editar mensagem com ou sem foto sem dar erro"""
    try:
        if query.message.caption or query.message.photo:
            await query.edit_message_caption(caption=text, reply_markup=reply_markup, parse_mode="Markdown")
        else:
            await query.edit_message_text(text=text, reply_markup=reply_markup, parse_mode="Markdown")
    except Exception as e:
        logging.error(f"Erro ao editar: {e}")

async def list_services(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    categories = get_categories()
    
    keyboard = []
    for i in range(0, len(categories), 2):
        cat_name = categories[i]
        callback_id = cat_name[:40] 
        row = [InlineKeyboardButton(cat_name, callback_data=f"cat_{callback_id}")]
        if i + 1 < len(categories):
            cat_name_2 = categories[i+1]
            callback_id_2 = cat_name_2[:40]
            row.append(InlineKeyboardButton(cat_name_2, callback_data=f"cat_{callback_id_2}"))
        keyboard.append(row)

    # APENAS VOLTAR AO MENU INICIAL AQUI
    keyboard.append([InlineKeyboardButton("🏠 Voltar ao Menu Principal", callback_data="back_to_start")])
    
    reply_markup = InlineKeyboardMarkup(keyboard)
    text = "📦 **ESCOLHA UMA CATEGORIA:**"

    if query:
        await query.answer()
        if query.message.photo:
            await query.edit_message_caption(caption=text, reply_markup=reply_markup, parse_mode="Markdown")
        else:
            await query.edit_message_text(text=text, reply_markup=reply_markup, parse_mode="Markdown")
    return SELECTING_SERVICE

async def category_services(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    
    # PEGA O DADO DO BOTÃO
    raw_data = query.data.replace("cat_", "")
    
    # LIMPEZA DO EMOJI: 
    # Se o nome veio como "📸 Instagram", o raw_data terá o emoji.
    # Vamos remover o emoji e o espaço inicial para buscar no banco.
    if " " in raw_data[:4]: # Se houver um espaço logo no começo (após o emoji)
        category_partial = raw_data.split(" ", 1)[1]
    else:
        category_partial = raw_data

    # Busca o nome real no banco usando LIKE
    conn = sqlite3.connect(str(DB_PATH))
    cursor = conn.cursor()
    cursor.execute(
        "SELECT DISTINCT category FROM services WHERE category LIKE ? AND rate > 0", 
        (f"%{category_partial}%",)
    )
    res = cursor.fetchone()
    conn.close()
    
    category = res[0] if res else category_partial
    services = get_services(category)
    
    # ... resto do código para gerar os botões dos serviços ...
    
    keyboard = [[InlineKeyboardButton(f"{s[1]} - R${s[2]:.2f}", callback_data=f"serv_{s[0]}") ] for s in services]
    
    # VOLTAR PARA A LISTA DE CATEGORIAS
    keyboard.append([InlineKeyboardButton("⬅️ Voltar para Categorias", callback_data="back_to_categories")])
    
    reply_markup = InlineKeyboardMarkup(keyboard)
    text = f"🚀 **SERVIÇOS: {category.upper()}**"

    if query.message.photo:
        await query.edit_message_caption(caption=text, reply_markup=reply_markup, parse_mode="Markdown")
    else:
        await query.edit_message_text(text=text, reply_markup=reply_markup, parse_mode="Markdown")
    return SELECTING_SERVICE

async def receive_service(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    
    service_id = query.data.replace("serv_", "")
    service = get_service_by_id(service_id)

    # Salva os dados no context
    context.user_data.update({
        "service_id": service[0],
        "category_parent": service[5] # Guardamos a categoria para o botão voltar
    })

    text = (
        f"📦 **{service[1]}**\n\n"
        f"💰 Preço por 1000: R$ {service[2]:.2f}\n"
        f"📉 Mínimo: {service[3]} | 📈 Máximo: {service[4]}\n\n"
        f"❓ **Quanto deseja comprar?**"
    )

    # VOLTAR PARA A LISTA DE SERVIÇOS DAQUELA CATEGORIA
    # O callback_data usa a categoria salva para reabrir a lista correta
    cat_id = service[5][:40]
    keyboard = [[InlineKeyboardButton("⬅️ Voltar para Serviços", callback_data=f"cat_{cat_id}")]]
    reply_markup = InlineKeyboardMarkup(keyboard)

    if query.message.photo:
        await query.edit_message_caption(caption=text, reply_markup=reply_markup, parse_mode="Markdown")
    else:
        await query.edit_message_text(text=text, reply_markup=reply_markup, parse_mode="Markdown")
    return ASKING_QUANTITY

async def receive_quantity(update: Update, context: ContextTypes.DEFAULT_TYPE):
    try:
        qty = int(update.message.text)
        min_q = context.user_data["service_min"]
        max_q = context.user_data["service_max"]

        if qty < min_q or qty > max_q:
            await update.message.reply_text(f"❌ Valor fora do limite! Digite entre {min_q} e {max_q}:")
            return ASKING_QUANTITY

        total = (qty / 1000) * context.user_data["service_rate"]
        context.user_data["total_price"] = total
        context.user_data["quantity"] = qty

        await update.message.reply_text("🔗 **Envie o link do Perfil ou Post:**")
        return ASKING_LINK

    except ValueError:
        await update.message.reply_text("⚠️ Por favor, digite apenas números inteiros.")
        return ASKING_QUANTITY

async def receive_link(update: Update, context: ContextTypes.DEFAULT_TYPE):
    link = update.message.text
    context.user_data["link"] = link

    resumo = (
        f"⚠️ **CONFIRMAÇÃO DO PEDIDO**\n\n"
        f"📦 Serviço: {context.user_data['service_name']}\n"
        f"🔢 Quantidade: {context.user_data['quantity']}\n"
        f"🔗 Link: `{link}`\n"
        f"💰 Total: **R$ {context.user_data['total_price']:.2f}**\n\n"
        f"✅ Digite `/confirmar` para finalizar ou `/cancelar` para desistir."
    )
    await update.message.reply_text(resumo, parse_mode="Markdown")
    return CONFIRMING

async def cancel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("❌ Ação cancelada com sucesso.")
    return ConversationHandler.END

